# Site
VITE_SITE_URL=https://www.smartestgaragedoors.com

# Form notifications – set at least ONE so you receive lead emails
# See FORM_SETUP.md for setup instructions.

# Option A: Resend (Vercel only – add these in Vercel Dashboard, not .env)
# RESEND_API_KEY=re_xxxxx
# NOTIFICATION_EMAIL=info@smartestgaragedoors.com
# FROM_EMAIL=Smartest Garage Doors <noreply@smartestgaragedoors.com>

# Option B: Web3Forms (works everywhere)
# VITE_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key

# Option C: Formspree (works everywhere)
# VITE_FORMSPREE_FORM_ID=your_formspree_form_id

# Supabase (existing)
VITE_PUBLIC_SUPABASE_URL=
VITE_PUBLIC_SUPABASE_ANON_KEY=

# Google Places (existing)
VITE_GOOGLE_PLACES_API_KEY=
